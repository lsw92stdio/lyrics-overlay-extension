{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "1.5.1",
  "description": "SRT 파일 기반 싱크 가사를 화면 위에 오버레이로 표시합니다. 원문/발음/번역 3줄 표시",
  "default_locale": "en",
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": ["https://docs.google.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/srt-parser.js", "lib/sheet-parser.js", "lib/i18n.js", "content/content.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
